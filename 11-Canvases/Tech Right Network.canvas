{
  "nodes": [
    {"id": "h", "type": "text", "text": "# Tech Right Network\n\n2024-2026 convergence of Silicon Valley + Trump 2.0", "x": -800, "y": -800, "width": 500, "height": 120},

    {"id": "thiel", "type": "text", "text": "## PETER THIEL\nCentral patriarch\n\n- Co-founded PayPal, Palantir, Founders Fund\n- First SV billionaire Trump backer (2016)\n- Funded JD Vance throughout career\n- Facebook board 2005-2022", "x": -200, "y": -500, "width": 350, "height": 230},

